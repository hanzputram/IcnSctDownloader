# === IconScout Bot Configuration ===

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/iconscout.db

# Download Settings
DOWNLOAD_DIR=./downloads
DOWNLOAD_DELAY_MIN=3
DOWNLOAD_DELAY_MAX=6
MAX_CONCURRENT_DOWNLOADS=2
DEFAULT_FORMAT=png

# Encryption key for storing passwords (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Google Drive (optional)
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_CREDENTIALS_FILE=./credentials.json
GOOGLE_DRIVE_FOLDER_ID=

# IconScout API (optional, if you have API access)
ICONSCOUT_API_CLIENT_ID=
ICONSCOUT_API_CLIENT_SECRET=

# Playwright
HEADLESS=true
BROWSER_TIMEOUT=30000

# Proxy Settings (Optional) - Comma separated list of proxies
PROXY_LIST=

